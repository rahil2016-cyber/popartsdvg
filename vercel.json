{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://poparts-api.joballocate.tech/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://poparts-api.joballocate.tech/uploads/:path*"
    }
  ]
}
